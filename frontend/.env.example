# Copy to `.env` for local development.
# Leave Entra values blank to run without sign-in against a dev backend
# (AUTH_DISABLED=true). Set all three to enable Entra ID SSO.

VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
# API scope exposed by the backend app registration, e.g.
# api://<api-client-id>/access_as_user
VITE_ENTRA_API_SCOPE=
